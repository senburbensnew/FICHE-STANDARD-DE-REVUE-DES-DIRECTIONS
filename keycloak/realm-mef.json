{
  "realm": "mef",
  "displayName": "Ministère de l'Économie et des Finances",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "accessTokenLifespan": 300,
  "refreshTokenMaxReuse": 0,

  "roles": {
    "realm": [
      { "name": "admin",              "description": "Administrateur — accès complet" },
      { "name": "responsable",        "description": "Responsable de direction — saisie et suivi des revues" },
      { "name": "direction-generale", "description": "Direction Générale — consultation et validation" }
    ]
  },

  "clients": [
    {
      "clientId": "mef-form",
      "name": "MEF Form (Frontend)",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": [
        "http://localhost/*",
        "http://localhost:5173/*"
      ],
      "webOrigins": [
        "http://localhost",
        "http://localhost:5173"
      ],
      "defaultClientScopes": ["web-origins", "profile", "roles", "email"]
    },
    {
      "clientId": "mef-backend",
      "name": "MEF Backend (API)",
      "enabled": true,
      "publicClient": false,
      "bearerOnly": true,
      "standardFlowEnabled": false
    }
  ],

  "users": [
    {
      "username": "admin.mef",
      "email": "admin@mef.gouv.ht",
      "firstName": "Admin",
      "lastName": "MEF",
      "enabled": true,
      "credentials": [{ "type": "password", "value": "Admin@1234", "temporary": true }],
      "realmRoles": ["admin"],
      "attributes": {
        "fonction":     ["Administrateur Système"],
        "telephone":    [""],
        "actif":        ["true"],
        "direction_id": [""]
      }
    }
  ]
}
